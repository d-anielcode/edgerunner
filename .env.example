# EdgeRunner Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# Trading Mode (CRITICAL SAFETY SWITCH)
TRADING_MODE=paper

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Kalshi Demo (Paper Trading)
KALSHI_API_KEY_ID=your-demo-key-id
KALSHI_PRIVATE_KEY_PATH=./keys/demo_private_key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2

# Kalshi Production (DO NOT FILL UNTIL MONTH 2)
# KALSHI_PROD_API_KEY_ID=
# KALSHI_PROD_PRIVATE_KEY_PATH=
# KALSHI_PROD_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Data Feeds (Optional)
BALLDONTLIE_API_KEY=
NBA_POLL_INTERVAL=45.0
ORDERBOOK_STALE_THRESHOLD=30.0

# Smart Money (Polymarket leaderboard — read-only, no auth)
SMART_MONEY_POLL_INTERVAL=600.0
SMART_MONEY_MIN_TRADERS=3

# Risk Parameters
MAX_POSITION_PCT=0.05
FRACTIONAL_KELLY=0.20
MAX_CONCURRENT_POSITIONS=10
MIN_EDGE_THRESHOLD=0.05
MAX_SPREAD_CENTS=0.03

# Budget Guard
CLAUDE_MONTHLY_BUDGET_LIMIT=45.00

# Debug
DEBUG_MODE=false
